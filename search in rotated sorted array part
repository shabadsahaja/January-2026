#WITHOUT O(log n)

arr=list(map(int,input().split()))
k=int(input())
target=int(input())
n=len(arr)
k=k%n
temp=arr[:k]
for i in range(k,n):
    arr[i-k]=arr[i]
for i in range(n-k,n):
    arr[i]=temp[i-(n-k)]
for i in range(n):
    if target==arr[i]:
        print(i)
        break
else:
    print(-1)
