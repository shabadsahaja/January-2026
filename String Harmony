inp=input()
n=len(inp)
ans=0
for start in range(n):
    pos=start
    current_len=0
    block_len=2
    while True:
        expected=""
        for i in range(block_len):
            expected+=chr(ord('a')+i)
        if pos<=n and inp[pos:pos+block_len]==expected:
            current_len+=block_len
            pos+=block_len
            block_len+=1
        else:
            break
    ans=max(ans, current_len)
print(ans)
