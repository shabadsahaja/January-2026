class Solution:
    def twoSum(self, numbers,target):
        i=0
        j=len(numbers)-1
        while i<j:
            TwoSum=numbers[i]+numbers[j]
            if TwoSum==target:
                return [i+1,j+1]
            elif TwoSum<target:
                i+=1
            else:
                j-=1
        
